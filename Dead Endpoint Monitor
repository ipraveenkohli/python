# Dead Endpoint Mointer 

import requests

SERVICES = ["https://api.myapp.com/health", "https://auth.myapp.com/status"]
WEBHOOK_URL = "https://hooks.slack.com/services/T000/B000/XXXX"

for url in SERVICES:
    try:
        r = requests.get(url, timeout=5)
        if r.status_code != 200:
            requests.post(WEBHOOK_URL, json={"text": f"🚨 Service Down: {url} (Status: {r.status_code})"})
    except Exception as e:
        requests.post(WEBHOOK_URL, json={"text": f"🔥 Connection Failed: {url} - {e}"})
