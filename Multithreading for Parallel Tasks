#Multithreading for Parallel Tasks


Run 5 tasks in parallel using threading.


import threading
import time

def task(name):
    print(f"Starting {name}")
    time.sleep(2)
    print(f"Finished {name}")

threads = []

for i in range(5):
    t = threading.Thread(target=task, args=(f"Task-{i}",))
    threads.append(t)
    t.start()

for t in threads:
    t.join()
